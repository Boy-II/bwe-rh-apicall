# 本地開發環境變數範本
# 複製為 .env 後填入實際值（.env 已在 .gitignore，不會被推上 git）

# ===== RunningHub =====
RUNNINGHUB_API_KEY=your_runninghub_api_key_here
RUNNINGHUB_BASE_URL=https://www.runninghub.ai

# ===== 管理員 =====
ADMIN_PASSWORD=change_this_password

# ===== JWT 簽名金鑰（強烈建議手動設定，避免 DB 重置時 token 失效） =====
JWT_SECRET=generate_a_random_64_char_hex_here

# ===== Gemini fallback（可選） =====
GEMINI_API_KEY=

# ===== AI 助手（可選；admin 介面也能設定，會寫進 settings 表） =====
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# ===== PostgreSQL（n8n 同款命名） =====
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5433
DB_POSTGRESDB_DATABASE=rhapi
DB_POSTGRESDB_USER=rhapi
DB_POSTGRESDB_PASSWORD=rhapi_local_dev

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ===== App =====
PORT=8000
POLLING_INTERVAL=3000
